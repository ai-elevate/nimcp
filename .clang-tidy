---
# NIMCP Clang-Tidy Configuration
# Comprehensive static analysis for C/C++ mixed codebase
# Documentation: https://clang.llvm.org/extra/clang-tidy/

# Check categories enabled:
# - bugprone-*: Detects bug-prone code patterns
# - performance-*: Performance optimization suggestions
# - readability-*: Code readability improvements
# - modernize-*: C++11/14/17 modernization (C++ only)
# - clang-analyzer-*: Deep static analysis
# - misc-*: Miscellaneous useful checks
# - cert-*: CERT secure coding guidelines

Checks: >
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-reserved-identifier,
  performance-*,
  readability-*,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-function-cognitive-complexity,
  clang-analyzer-*,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  misc-*,
  -misc-unused-parameters,
  -misc-no-recursion,
  cert-*,
  -cert-err33-c,
  -cert-dcl37-c,
  -cert-dcl51-cpp,
  portability-*,
  concurrency-*

# Disabled checks explanation:
# - bugprone-easily-swappable-parameters: Too noisy, many false positives
# - bugprone-reserved-identifier: Conflicts with common system header patterns
# - readability-identifier-length: Single char vars acceptable in math/loops
# - readability-magic-numbers: Too strict for system programming
# - readability-function-cognitive-complexity: Informational only, too strict
# - clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling: False positives on safe wrappers
# - misc-unused-parameters: Common in callback interfaces
# - misc-no-recursion: Sometimes necessary for tree/graph algorithms
# - cert-err33-c: Too strict for return value checking
# - cert-dcl37-c: Reserved identifiers - covered by other checks
# - cert-dcl51-cpp: Not applicable to C99 code

# Global options
WarningsAsErrors: ''
HeaderFilterRegex: '.*'
AnalyzeTemporaryDtors: false
FormatStyle: file

# Check-specific options
CheckOptions:
  # Naming conventions
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: lower_case
  - key: readability-identifier-naming.FunctionCase
    value: lower_case
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.ParameterCase
    value: lower_case
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
  - key: readability-identifier-naming.EnumConstantCase
    value: UPPER_CASE
  - key: readability-identifier-naming.ConstantCase
    value: UPPER_CASE
  - key: readability-identifier-naming.GlobalConstantCase
    value: UPPER_CASE
  - key: readability-identifier-naming.TypedefCase
    value: lower_case
  - key: readability-identifier-naming.TypedefSuffix
    value: _t

  # Readability options
  - key: readability-function-size.LineThreshold
    value: 100
  - key: readability-function-size.StatementThreshold
    value: 100
  - key: readability-function-size.BranchThreshold
    value: 20
  - key: readability-function-size.ParameterThreshold
    value: 6
  - key: readability-braces-around-statements.ShortStatementLines
    value: 0
  - key: readability-uppercase-literal-suffix.NewSuffixes
    value: 'L;LL;LU;LLU'

  # Performance options
  - key: performance-move-const-arg.CheckTriviallyCopyableMove
    value: true
  - key: performance-unnecessary-value-param.IncludeStyle
    value: google

  # Bug detection options
  - key: bugprone-assert-side-effect.AssertMacros
    value: 'assert,ASSERT,REQUIRE,CHECK'
  - key: bugprone-string-constructor.WarnOnLargeLength
    value: true
  - key: bugprone-suspicious-string-compare.WarnOnLogicalNotComparison
    value: true

  # Concurrency options
  - key: concurrency-mt-unsafe.FunctionSet
    value: 'posix'

  # Misc options
  - key: misc-non-private-member-variables-in-classes.IgnoreClassesWithAllMemberVariablesBeingPublic
    value: true

# Language-specific settings
# C99-specific exclusions (applied when analyzing .c files)
# The modernize-* checks are automatically skipped for C code
...
