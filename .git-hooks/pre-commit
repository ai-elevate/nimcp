#!/bin/bash
#==============================================================================
# NIMCP Pre-Commit Hook
#==============================================================================
# This hook runs before each commit to ensure code quality
#
# Installation:
#   cp .git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or use git config:
#   git config core.hooksPath .git-hooks
#
# To bypass this hook temporarily:
#   git commit --no-verify
#
# Checks performed:
# - Code formatting (clang-format)
# - Basic syntax checks
# - File size limits
# - TODO/FIXME detection (warning only)
#==============================================================================

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Script location
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$HOOK_DIR/../.." && pwd 2>/dev/null || cd "$HOOK_DIR/.." && pwd)"

print_header() {
    echo -e "${BLUE}========================================${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}========================================${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

print_info() {
    echo -e "${BLUE}ℹ $1${NC}"
}

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(c|cpp|h|hpp)$' || true)

if [ -z "$STAGED_FILES" ]; then
    print_info "No C/C++ files to check"
    exit 0
fi

print_header "Pre-Commit Hook - NIMCP Code Quality"

EXIT_CODE=0

#==============================================================================
# 1. Check clang-format (if available)
#==============================================================================
if command -v clang-format &> /dev/null; then
    print_info "Checking code formatting..."

    UNFORMATTED_FILES=""
    for file in $STAGED_FILES; do
        if [ -f "$file" ]; then
            if ! clang-format --dry-run --Werror "$file" &> /dev/null; then
                UNFORMATTED_FILES="$UNFORMATTED_FILES\n  - $file"
            fi
        fi
    done

    if [ -n "$UNFORMATTED_FILES" ]; then
        print_error "Files need formatting:"
        echo -e "$UNFORMATTED_FILES"
        print_info "Run: clang-format -i <file> to fix"
        print_info "Or: ./scripts/lint.sh --fix"
        EXIT_CODE=1
    else
        print_success "All files properly formatted"
    fi
else
    print_warning "clang-format not found - skipping format check"
fi

#==============================================================================
# 2. Check file sizes
#==============================================================================
print_info "Checking file sizes..."

LARGE_FILES=""
MAX_LINES=2000

for file in $STAGED_FILES; do
    if [ -f "$file" ] && [[ "$file" =~ \.c$ ]]; then
        LINES=$(wc -l < "$file")
        if [ "$LINES" -gt "$MAX_LINES" ]; then
            LARGE_FILES="$LARGE_FILES\n  - $file ($LINES lines)"
        fi
    fi
done

if [ -n "$LARGE_FILES" ]; then
    print_warning "Large files detected (>${MAX_LINES} lines):"
    echo -e "$LARGE_FILES"
    print_info "Consider refactoring large files"
    # Warning only, don't fail
fi

#==============================================================================
# 3. Check for syntax errors (basic)
#==============================================================================
if command -v gcc &> /dev/null; then
    print_info "Running basic syntax checks..."

    SYNTAX_ERRORS=""
    for file in $STAGED_FILES; do
        if [ -f "$file" ] && [[ "$file" =~ \.(c|cpp)$ ]]; then
            # Basic syntax check only (no linking)
            if ! gcc -fsyntax-only -I"$PROJECT_ROOT/src/include" "$file" 2>/dev/null; then
                SYNTAX_ERRORS="$SYNTAX_ERRORS\n  - $file"
            fi
        fi
    done

    if [ -n "$SYNTAX_ERRORS" ]; then
        print_error "Syntax errors detected in:"
        echo -e "$SYNTAX_ERRORS"
        EXIT_CODE=1
    else
        print_success "No syntax errors detected"
    fi
fi

#==============================================================================
# 4. Check for TODO/FIXME (informational)
#==============================================================================
print_info "Checking for TODO/FIXME..."

FIXME_COUNT=0
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        COUNT=$(grep -c "FIXME\|XXX" "$file" 2>/dev/null || echo 0)
        FIXME_COUNT=$((FIXME_COUNT + COUNT))
    fi
done

if [ $FIXME_COUNT -gt 0 ]; then
    print_warning "Found $FIXME_COUNT FIXME/XXX comments in staged files"
    print_info "Consider addressing before commit"
fi

#==============================================================================
# 5. Run quick lint if script available
#==============================================================================
if [ -x "$PROJECT_ROOT/scripts/lint.sh" ]; then
    print_info "Running quick lint checks on staged files..."

    # Create temp file list
    TEMP_FILE_LIST=$(mktemp)
    echo "$STAGED_FILES" > "$TEMP_FILE_LIST"

    # Run lint on staged files only
    if ! "$PROJECT_ROOT/scripts/lint.sh" $STAGED_FILES 2>&1 | tail -20; then
        print_warning "Lint script found issues (see above)"
        # Don't fail on lint warnings in pre-commit
    fi

    rm -f "$TEMP_FILE_LIST"
fi

#==============================================================================
# Summary
#==============================================================================
echo ""
print_header "Pre-Commit Check Summary"

if [ $EXIT_CODE -eq 0 ]; then
    print_success "All pre-commit checks passed!"
    echo ""
    print_info "Commit message tips:"
    echo "  - Use imperative mood (Add, Fix, Update)"
    echo "  - Keep first line under 50 chars"
    echo "  - Add detailed description after blank line"
    echo ""
else
    print_error "Pre-commit checks failed!"
    echo ""
    print_info "To bypass this hook (not recommended):"
    echo "  git commit --no-verify"
    echo ""
    print_info "To fix issues:"
    echo "  - Run: ./scripts/lint.sh --fix"
    echo "  - Fix syntax errors"
    echo "  - Re-stage fixed files: git add <file>"
    echo ""
fi

exit $EXIT_CODE
