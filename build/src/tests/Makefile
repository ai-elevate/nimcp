	cd /home/bbrelin/src/repos/nimcp/build && $(MAKE) $(MAKESILENT) -f src/tests/CMakeFiles/nimcp_tests.dir/build.make src/tests/CMakeFiles/nimcp_tests.dir/test_thread_utils.cpp.i
.PHONY : test_thread_utils.cpp.i

test_thread_utils.s: test_thread_utils.cpp.s
.PHONY : test_thread_utils.s

# target to generate assembly for a file
test_thread_utils.cpp.s:
	cd /home/bbrelin/src/repos/nimcp/build && $(MAKE) $(MAKESILENT) -f src/tests/CMakeFiles/nimcp_tests.dir/build.make src/tests/CMakeFiles/nimcp_tests.dir/test_thread_utils.cpp.s
.PHONY : test_thread_utils.cpp.s

