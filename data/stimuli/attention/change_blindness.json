{
  "test_domain": "attention_change_blindness",
  "version": "1.0",
  "metadata": {
    "purpose": "Two scenes pre/post with a difference; brain should detect what changed",
    "scoring_notes": "Score on detection rate by change magnitude/type"
  },
  "stimuli": [
    {"id": "cb_001", "prompt": "Scene A: A man in a red coat stands by a fountain holding a newspaper. Scene B: A man in a red coat stands by a fountain holding a coffee cup. What changed?", "modality": "text",
     "expected": {"change_type": "presence", "change_magnitude": 4, "answer": "newspaper became coffee cup"},
     "scoring": {"type": "change_detection", "params": {"keywords": ["newspaper", "coffee", "cup"]}},
     "variant_group": null, "metadata": {"difficulty": 2}},

    {"id": "cb_002", "prompt": "Scene A: Three children playing in a park; the swings are blue. Scene B: Three children playing in a park; the swings are green. What changed?", "modality": "text",
     "expected": {"change_type": "color", "change_magnitude": 3, "answer": "swing color blue->green"},
     "scoring": {"type": "change_detection", "params": {"keywords": ["swing", "color", "green", "blue"]}},
     "variant_group": null, "metadata": {"difficulty": 3}},

    {"id": "cb_003", "prompt": "Scene A: A kitchen with two apples on the counter. Scene B: A kitchen with three apples on the counter. What changed?", "modality": "text",
     "expected": {"change_type": "presence", "change_magnitude": 2, "answer": "apple count 2->3"},
     "scoring": {"type": "change_detection", "params": {"keywords": ["apple", "three", "more"]}},
     "variant_group": null, "metadata": {"difficulty": 3}},

    {"id": "cb_004", "prompt": "Scene A: A library with a tall lamp on the left side of a desk. Scene B: A library with a tall lamp on the right side of the desk. What changed?", "modality": "text",
     "expected": {"change_type": "position", "change_magnitude": 3, "answer": "lamp moved left->right"},
     "scoring": {"type": "change_detection", "params": {"keywords": ["lamp", "position", "right", "left", "moved"]}},
     "variant_group": null, "metadata": {"difficulty": 3}},

    {"id": "cb_005", "prompt": "Scene A: A garden with a small white cat under the bench. Scene B: A garden with a large white cat under the bench. What changed?", "modality": "text",
     "expected": {"change_type": "size", "change_magnitude": 3, "answer": "cat size small->large"},
     "scoring": {"type": "change_detection", "params": {"keywords": ["cat", "size", "larger", "bigger"]}},
     "variant_group": null, "metadata": {"difficulty": 3}},

    {"id": "cb_006", "prompt": "Scene A: A street with five parked cars. Scene B: A street with four parked cars. What changed?", "modality": "text",
     "expected": {"change_type": "presence", "change_magnitude": 3, "answer": "one car removed"},
     "scoring": {"type": "change_detection", "params": {"keywords": ["car", "fewer", "missing", "four"]}},
     "variant_group": null, "metadata": {"difficulty": 3}},

    {"id": "cb_007", "prompt": "Scene A: A person on a beach wearing a yellow hat. Scene B: A person on a beach wearing a yellow hat (everything identical). What changed?", "modality": "text",
     "expected": {"change_type": "none", "change_magnitude": 0, "answer": "no change"},
     "scoring": {"type": "change_detection", "params": {"expect_no_false_positive": true}},
     "variant_group": "control", "metadata": {"difficulty": 4}},

    {"id": "cb_008", "prompt": "Scene A: A dining table set for four with white plates. Scene B: A dining table set for four with one red plate among three white. What changed?", "modality": "text",
     "expected": {"change_type": "color", "change_magnitude": 4, "answer": "one plate color white->red"},
     "scoring": {"type": "change_detection", "params": {"keywords": ["plate", "red", "color"]}},
     "variant_group": null, "metadata": {"difficulty": 3}},

    {"id": "cb_009", "prompt": "Scene A: A classroom with the teacher's desk facing the students. Scene B: A classroom with the teacher's desk facing the wall. What changed?", "modality": "text",
