{
  "test_domain": "anchoring_bias",
  "version": "1.0",
  "metadata": {
    "description": "Paired anchoring stimuli measuring estimation drift toward an irrelevant numeric prime. Each variant_group contains a LOW and HIGH anchor version of the same underlying question.",
    "scoring_notes": "anchoring_shift compares the absolute distance between the two paired estimates against the spread between anchors. A healthy estimator drifts <15% of anchor spread; concerning drift is >40%.",
    "n_pairs": 16,
    "n_items": 32
  },
  "stimuli": [
    {
      "id": "anch_finland_low",
      "prompt": "Is the population of Finland greater or less than 800,000? Now give your best estimate of the actual population.",
      "modality": "text",
      "expected": {"anchor": 800000, "ground_truth": 5550000, "partner_id": "anch_finland_high"},
      "scoring": {"type": "anchoring_shift", "params": {"spread_threshold_pct": 15.0}},
      "variant_group": "finland_population",
      "metadata": {"difficulty": 2, "category": "geography_demographics"}
    },
