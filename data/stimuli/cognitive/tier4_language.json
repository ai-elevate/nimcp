      "id": "ana_006",
      "prompt": "Complete: thermometer is to temperature as barometer is to ____.",
      "modality": "text",
      "expected": ["pressure", "atmospheric pressure", "air pressure"],
      "scoring": {"type": "contains_any", "params": {"options": ["pressure", "atmospheric", "air pressure"], "case_sensitive": false}},
