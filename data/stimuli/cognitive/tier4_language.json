      "expected": ["nothing", "no information", "unknown", "not specified", "not stated"],
      "scoring": {"type": "contains_any", "params": {"options": ["nothing", "unknown", "not specified", "not stated", "no information", "unstated", "not mentioned"], "case_sensitive": false}},
      "variant_group": "compositional_inference",
      "metadata": {"difficulty": 4, "rationale": "tests resistance to assuming details not given"}
    },
    {
      "id": "comp_006",
      "prompt": "Scene: 'Two dogs and three cats are playing; each cat has a red collar and each dog has a blue collar.' How many blue collars are there?",
      "modality": "text",
