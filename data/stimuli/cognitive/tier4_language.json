      "scoring": {"type": "contains_any", "params": {"options": ["square", "red square"], "case_sensitive": false}},
      "variant_group": "compositional_nested",
      "metadata": {"difficulty": 4}
    },
    {
      "id": "comp_005",
      "prompt": "Scene: 'A black cat is sitting on a brown mat under a white table.' What is on top of the table?",
