      "scoring": {"type": "contains_any", "params": {"options": ["snail", "nautilus", "conch", "whelk", "sea snail"], "case_sensitive": false}},
      "variant_group": "pic_word",
      "metadata": {"difficulty": 3}
    },
    {
      "id": "pic_007",
      "prompt": "An image shows a desert plant with thick green padded segments covered in sharp spines and small white flowers. Single word?",
      "modality": "text",
      "expected": ["cactus"],
      "scoring": {"type": "contains_any", "params": {"options": ["cactus", "prickly pear", "succulent"], "case_sensitive": false}},
