{
  "test_domain": "cognitive.tier4.language",
  "version": "1.0",
  "metadata": {
    "notes": "Probes core language capacities: picture-word matching from descriptions, analogy completion, sentence-meaning probes, compositional understanding, and Gricean implicature. Items use novel scenarios to avoid memorized patterns.",
    "subtasks": ["picture_word", "analogy", "sentence_meaning", "composition", "implicature"],
    "n_items": 35
  },
  "stimuli": [
    {
      "id": "pic_001",
      "prompt": "An image shows a small object that has a long thin handle, a flat circular head with bristles, and is used for cleaning teeth. What is the single English word for this object?",
      "modality": "text",
      "expected": "toothbrush",
      "scoring": {"type": "exact_match", "params": {"case_sensitive": false, "normalize_whitespace": true, "strip_punctuation": true}},
      "variant_group": "pic_word",
      "metadata": {"difficulty": 1}
    },
    {
      "id": "pic_002",
      "prompt": "An image shows a tall, conical green tree with needle-like leaves, often decorated in winter. What is the single English word?",
      "modality": "text",
      "expected": ["pine", "fir", "spruce", "evergreen", "conifer", "christmas tree"],
      "scoring": {"type": "contains_any", "params": {"options": ["pine", "fir", "spruce", "evergreen", "conifer", "christmas tree"], "case_sensitive": false}},
      "variant_group": "pic_word",
      "metadata": {"difficulty": 1}
    },
    {
      "id": "pic_003",
      "prompt": "An image shows a circular instrument worn on the wrist, with rotating hands pointing to numbers, used to tell time. Single word?",
