    {
      "id": "ana_007",
      "prompt": "Complete: famine is to food as drought is to ____.",
      "modality": "text",
      "expected": ["water", "rain", "rainfall", "moisture"],
      "scoring": {"type": "contains_any", "params": {"options": ["water", "rain", "rainfall", "moisture", "precipitation"], "case_sensitive": false}},
