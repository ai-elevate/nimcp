      "variant_group": "analogy_offspring",
      "metadata": {"difficulty": 1}
    },
    {
      "id": "ana_002",
      "prompt": "Complete: hand is to glove as foot is to ____.",
      "modality": "text",
      "expected": ["sock", "shoe", "boot"],
