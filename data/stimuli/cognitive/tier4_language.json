      "modality": "text",
      "expected": ["on", "above", "atop"],
      "scoring": {"type": "contains_any", "params": {"options": ["on", "atop", "on top", "above"], "case_sensitive": false}},
      "variant_group": "compositional_spatial",
      "metadata": {"difficulty": 1}
    },
