      "prompt": "Complete: Spain is to peseta as Japan is to ____. (Note: think of historical or pre-euro currencies.)",
      "modality": "text",
      "expected": "yen",
      "scoring": {"type": "exact_match", "params": {"case_sensitive": false, "normalize_whitespace": true, "strip_punctuation": true}},
      "variant_group": "analogy_country_currency",
      "metadata": {"difficulty": 3}
    },
    {
      "id": "ana_010",
      "prompt": "Complete: cobbler is to shoes as cooper is to ____.",
      "modality": "text",
      "expected": ["barrels", "casks", "kegs"],
      "scoring": {"type": "contains_any", "params": {"options": ["barrels", "casks", "kegs", "barrel"], "case_sensitive": false}},
      "variant_group": "analogy_craftsperson",
      "metadata": {"difficulty": 5}
    },
    {
      "id": "sm_001",
      "prompt": "Sentence: 'Although Marcus practiced daily, he never improved at the violin.' What does this sentence imply about Marcus's improvement on the violin? Answer in one word: improved or did-not-improve.",
      "modality": "text",
      "expected": "did-not-improve",
      "scoring": {"type": "contains_any", "params": {"options": ["did not improve", "did-not-improve", "no improvement", "didn't improve", "not improved"], "case_sensitive": false}},
      "variant_group": "sentence_concession",
      "metadata": {"difficulty": 2}
    },
    {
      "id": "sm_002",
      "prompt": "Sentence: 'The package, which had been left on the porch overnight, was soaked.' What was soaked: the package or the porch?",
      "modality": "text",
      "expected": "package",
      "scoring": {"type": "exact_match", "params": {"case_sensitive": false, "normalize_whitespace": true, "strip_punctuation": true}},
      "variant_group": "sentence_relative",
      "metadata": {"difficulty": 2}
    },
    {
      "id": "sm_003",
      "prompt": "Sentence: 'Lena managed to fix the leaking faucet despite never having done plumbing before.' Did Lena succeed? Answer 'yes' or 'no'.",
      "modality": "text",
      "expected": "yes",
      "scoring": {"type": "exact_match", "params": {"case_sensitive": false, "normalize_whitespace": true, "strip_punctuation": true}},
      "variant_group": "sentence_factive",
      "metadata": {"difficulty": 2, "rationale": "'managed to' implies success"}
    },
    {
      "id": "sm_004",
      "prompt": "Sentence: 'The senator regretted voting for the bill.' Did the senator vote for the bill? Answer 'yes' or 'no'.",
      "modality": "text",
      "expected": "yes",
      "scoring": {"type": "exact_match", "params": {"case_sensitive": false, "normalize_whitespace": true, "strip_punctuation": true}},
      "variant_group": "sentence_presupposition",
      "metadata": {"difficulty": 3, "rationale": "'regretted X' presupposes X happened"}
    },
    {
      "id": "sm_005",
      "prompt": "Sentence: 'No student in the class failed the exam.' Did anyone in the class fail? 'yes' or 'no'.",
      "modality": "text",
      "expected": "no",
      "scoring": {"type": "exact_match", "params": {"case_sensitive": false, "normalize_whitespace": true, "strip_punctuation": true}},
      "variant_group": "sentence_quantifier",
      "metadata": {"difficulty": 2}
    },
    {
      "id": "sm_006",
      "prompt": "Sentence: 'It is not the case that every reviewer disliked the film.' Did every reviewer dislike the film? 'yes' or 'no'.",
      "modality": "text",
      "expected": "no",
      "scoring": {"type": "exact_match", "params": {"case_sensitive": false, "normalize_whitespace": true, "strip_punctuation": true}},
      "variant_group": "sentence_negation_scope",
      "metadata": {"difficulty": 4}
    },
