      "metadata": {"difficulty": 1}
    },
    {
      "id": "pic_008",
      "prompt": "An image shows a curved metal instrument with a serrated edge, used in surgery to cut tissue precisely. Single word?",
      "modality": "text",
      "expected": ["scalpel", "scissors", "saw"],
      "scoring": {"type": "contains_any", "params": {"options": ["scalpel", "surgical scissors", "bone saw", "surgical saw"], "case_sensitive": false}},
      "variant_group": "pic_word",
