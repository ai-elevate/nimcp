    {"id": "sub_08", "prompt": "Quick — a brief flash shows: . . . . .  Just give your immediate sense — how many?", "modality": "text", "expected": "5 (boundary of subitizing)", "scoring": {"type": "exact_match", "params": {"normalize": "digit"}}, "variant_group": "subitizing_boundary", "metadata": {"difficulty": 3}},
    {"id": "ans_01", "prompt": "Which group has more items: a group of 30 or a group of 45?", "modality": "text", "expected": "45", "scoring": {"type": "contains_any", "params": {"options": ["45", "forty-five", "second", "the second"]}}, "variant_group": "ans_easy", "metadata": {"difficulty": 1}},
    {"id": "ans_02", "prompt": "Which is more: 18 marbles or 24 marbles?", "modality": "text", "expected": "24", "scoring": {"type": "contains_any", "params": {"options": ["24", "twenty-four", "second"]}}, "variant_group": "ans_easy", "metadata": {"difficulty": 1}},
