    {"id": "ans_04", "prompt": "Which is more: 199 or 201?", "modality": "text", "expected": "201", "scoring": {"type": "contains_any", "params": {"options": ["201", "two hundred and one", "second"]}}, "variant_group": "ans_close", "metadata": {"difficulty": 3}},
    {"id": "ans_05", "prompt": "Which has a larger population (rough sense): a flock of about 60 birds or a flock of about 100 birds?", "modality": "text", "expected": "the flock of 100", "scoring": {"type": "contains_any", "params": {"options": ["100", "hundred", "second"]}}, "variant_group": "ans_easy", "metadata": {"difficulty": 1}},
    {"id": "ans_06", "prompt": "Without counting, which jar likely has more jellybeans: one with about 250 or one with about 350?", "modality": "text", "expected": "the jar with about 350", "scoring": {"type": "contains_any", "params": {"options": ["350", "second"]}}, "variant_group": "ans_estimation", "metadata": {"difficulty": 2}},
    {"id": "ans_07", "prompt": "Which is more: 16 or 17?", "modality": "text", "expected": "17", "scoring": {"type": "contains_any", "params": {"options": ["17", "seventeen", "second"]}}, "variant_group": "ans_hard", "metadata": {"difficulty": 4}},
    {"id": "ans_08", "prompt": "Two lines of cars: one has 12 cars, the other has 19. Which is longer?", "modality": "text", "expected": "the line with 19", "scoring": {"type": "contains_any", "params": {"options": ["19", "nineteen", "second"]}}, "variant_group": "ans_easy", "metadata": {"difficulty": 1}},
    {"id": "rot_01", "prompt": "An L-shape is rotated 90 degrees clockwise. The result is then compared to the original L-shape. Are they the same shape (just rotated) or is one a mirror image of the other?", "modality": "text", "expected": "same shape", "scoring": {"type": "contains_any", "params": {"options": ["same", "rotated"]}}, "variant_group": "rotation_same", "metadata": {"difficulty": 2}},
