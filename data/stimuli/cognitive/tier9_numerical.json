    {"id": "ari_02", "prompt": "While remembering the digits 4-9-2 for later, compute: 13 + 28 = ?", "modality": "text", "expected": "41", "scoring": {"type": "exact_match", "params": {"normalize": "digit"}}, "variant_group": "arithmetic_load", "metadata": {"difficulty": 3}},
    {"id": "ari_03", "prompt": "12 x 7 = ?", "modality": "text", "expected": "84", "scoring": {"type": "exact_match", "params": {"normalize": "digit"}}, "variant_group": "arithmetic_basic", "metadata": {"difficulty": 2}},
    {"id": "ari_04", "prompt": "While counting backward from 20 in your head, compute 36 - 19. What is the answer?", "modality": "text", "expected": "17", "scoring": {"type": "exact_match", "params": {"normalize": "digit"}}, "variant_group": "arithmetic_load", "metadata": {"difficulty": 4}},
