    {"id": "rot_04", "prompt": "A triangle with vertices labeled A (top), B (bottom-left), C (bottom-right) is rotated 90 degrees counter-clockwise. Where is vertex A now?", "modality": "text", "expected": "left", "scoring": {"type": "contains_any", "params": {"options": ["left"]}}, "variant_group": "rotation", "metadata": {"difficulty": 3}},
    {"id": "rot_05", "prompt": "A right-handed glove is rotated and turned in space. Can it ever look identical to a left-handed glove without being flipped through a mirror?", "modality": "text", "expected": "no", "scoring": {"type": "exact_match", "params": {"normalize": "lower_strip"}}, "variant_group": "rotation_chirality", "metadata": {"difficulty": 4}},
    {"id": "rot_06", "prompt": "The number '6' is rotated 180 degrees. What does it look like?", "modality": "text", "expected": "a 9", "scoring": {"type": "contains_any", "params": {"options": ["9", "nine"]}}, "variant_group": "rotation", "metadata": {"difficulty": 2}},
    {"id": "rot_07", "prompt": "The capital letter 'p' is rotated 180 degrees. What letter does it most resemble?", "modality": "text", "expected": "d (lowercase) or 'b' depending on font; in serif fonts often 'd'", "scoring": {"type": "contains_any", "params": {"options": ["d", "b"]}}, "variant_group": "rotation", "metadata": {"difficulty": 3}},
    {"id": "rot_08", "prompt": "Imagine a cube with a red face on top and a blue face facing you. The cube is rotated so the red face is now facing you. Where is the blue face?", "modality": "text", "expected": "on the bottom", "scoring": {"type": "contains_any", "params": {"options": ["bottom", "underneath", "below"]}}, "variant_group": "rotation_3d", "metadata": {"difficulty": 4}},
