    {"id": "sub_03", "prompt": "Quick — count: .  How many dots?", "modality": "text", "expected": "1", "scoring": {"type": "exact_match", "params": {"normalize": "digit"}}, "variant_group": "subitizing", "metadata": {"difficulty": 1}},
    {"id": "sub_04", "prompt": "Quick — count: . . . .  How many dots?", "modality": "text", "expected": "4", "scoring": {"type": "exact_match", "params": {"normalize": "digit"}}, "variant_group": "subitizing", "metadata": {"difficulty": 1}},
