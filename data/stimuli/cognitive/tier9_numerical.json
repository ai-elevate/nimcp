    {"id": "ari_07", "prompt": "100 - 37 = ?", "modality": "text", "expected": "63", "scoring": {"type": "exact_match", "params": {"normalize": "digit"}}, "variant_group": "arithmetic_basic", "metadata": {"difficulty": 1}}
