{
  "test_domain": "game_theory_ultimatum",
  "version": "1.0",
  "metadata": {
    "purpose": "Ultimatum-game splits varying in fairness; brain plays as responder (accept/reject) and proposer",
    "scoring_notes": "fair_threshold ~0.3 means humans typically reject offers below 30%"
  },
  "stimuli": [
    {"id": "ult_001", "prompt": "You are offered a split of $100. The proposer keeps $50, you get $50. Accept or reject?", "modality": "text",
     "expected": {"split": [50, 50], "fair_threshold": 0.3, "expected_response": "accept", "role": "responder"},
     "scoring": {"type": "ultimatum_decision", "params": {}},
     "variant_group": "ult_responder", "metadata": {"difficulty": 1}},

    {"id": "ult_002", "prompt": "You are offered a split of $100. The proposer keeps $80, you get $20. Accept or reject?", "modality": "text",
     "expected": {"split": [80, 20], "fair_threshold": 0.3, "expected_response": "reject", "role": "responder"},
     "scoring": {"type": "ultimatum_decision", "params": {}},
     "variant_group": "ult_responder", "metadata": {"difficulty": 2}},

    {"id": "ult_003", "prompt": "You are offered a split of $100. The proposer keeps $99, you get $1. Accept or reject?", "modality": "text",
     "expected": {"split": [99, 1], "fair_threshold": 0.3, "expected_response": "reject", "role": "responder"},
     "scoring": {"type": "ultimatum_decision", "params": {}},
     "variant_group": "ult_responder", "metadata": {"difficulty": 1}},

    {"id": "ult_004", "prompt": "You are offered a split of $100. The proposer keeps $60, you get $40. Accept or reject?", "modality": "text",
     "expected": {"split": [60, 40], "fair_threshold": 0.3, "expected_response": "accept", "role": "responder"},
     "scoring": {"type": "ultimatum_decision", "params": {}},
     "variant_group": "ult_responder", "metadata": {"difficulty": 2}},

    {"id": "ult_005", "prompt": "You are offered a split of $100. The proposer keeps $70, you get $30. Accept or reject?", "modality": "text",
     "expected": {"split": [70, 30], "fair_threshold": 0.3, "expected_response": "borderline", "role": "responder"},
     "scoring": {"type": "ultimatum_decision", "params": {"borderline_ok": true}},
     "variant_group": "ult_responder", "metadata": {"difficulty": 3}},

    {"id": "ult_006", "prompt": "Stakes are now $10. The proposer keeps $9, you get $1. Accept or reject?", "modality": "text",
     "expected": {"split": [9, 1], "fair_threshold": 0.3, "expected_response": "reject", "role": "responder", "low_stakes": true},
     "scoring": {"type": "ultimatum_decision", "params": {}},
     "variant_group": "ult_low_stakes", "metadata": {"difficulty": 2}},

    {"id": "ult_007", "prompt": "Stakes are $10,000. The proposer keeps $8,000, you get $2,000. Accept or reject?", "modality": "text",
     "expected": {"split": [8000, 2000], "fair_threshold": 0.3, "expected_response": "borderline", "role": "responder", "high_stakes": true},
     "scoring": {"type": "ultimatum_decision", "params": {"borderline_ok": true}},
     "variant_group": "ult_high_stakes", "metadata": {"difficulty": 3}},

    {"id": "ult_008", "prompt": "Stakes are $1,000,000. The proposer keeps $990,000, you get $10,000. Accept or reject?", "modality": "text",
     "expected": {"split": [990000, 10000], "fair_threshold": 0.3, "expected_response": "ambivalent", "role": "responder", "extreme_stakes": true},
     "scoring": {"type": "ultimatum_decision", "params": {"justify_required": true}},
     "variant_group": "ult_extreme_stakes", "metadata": {"difficulty": 4}},

    {"id": "ult_009", "prompt": "You are the proposer with $100 to split. What do you offer the responder?", "modality": "text",
     "expected": {"split": [60, 40], "fair_threshold": 0.3, "expected_response": "offer_30_to_50", "role": "proposer"},
     "scoring": {"type": "ultimatum_offer", "params": {"min_offer_percent": 30, "max_offer_percent": 50}},
     "variant_group": "ult_proposer", "metadata": {"difficulty": 3}},

    {"id": "ult_010", "prompt": "You are the proposer with $1,000 to split with a stranger you'll never meet again. What do you offer?", "modality": "text",
     "expected": {"split": [600, 400], "fair_threshold": 0.3, "expected_response": "offer_30_to_50", "role": "proposer", "anonymous": true},
     "scoring": {"type": "ultimatum_offer", "params": {"min_offer_percent": 25, "max_offer_percent": 50}},
     "variant_group": "ult_proposer_anon", "metadata": {"difficulty": 3}},

    {"id": "ult_011", "prompt": "You earned the $100 by working harder than the responder. Now propose a split.", "modality": "text",
     "expected": {"split": [70, 30], "fair_threshold": 0.2, "expected_response": "offer_lower_with_justification", "role": "proposer", "earned": true},
     "scoring": {"type": "ultimatum_offer", "params": {"min_offer_percent": 20, "max_offer_percent": 40, "justify_expected": true}},
     "variant_group": "ult_earned", "metadata": {"difficulty": 4}},

    {"id": "ult_012", "prompt": "The responder is your friend. You have $100 to split. Propose.", "modality": "text",
     "expected": {"split": [50, 50], "fair_threshold": 0.4, "expected_response": "offer_close_to_half_or_more", "role": "proposer", "social_tie": true},
     "scoring": {"type": "ultimatum_offer", "params": {"min_offer_percent": 40, "max_offer_percent": 60}},
     "variant_group": "ult_friend", "metadata": {"difficulty": 2}},

    {"id": "ult_013", "prompt": "The responder is known to accept any offer above $0. You have $100. What do you offer?", "modality": "text",
     "expected": {"split": [99, 1], "fair_threshold": 0.0, "expected_response": "test_of_principle", "role": "proposer", "known_minimum": true},
     "scoring": {"type": "ultimatum_offer", "params": {"justify_expected": true}},
     "variant_group": "ult_min_acceptor", "metadata": {"difficulty": 5}},

    {"id": "ult_014", "prompt": "The proposer offers a 50/50 split, but with a sneer that suggests contempt. Accept or reject?", "modality": "text",
     "expected": {"split": [50, 50], "fair_threshold": 0.3, "expected_response": "accept_with_discomfort", "role": "responder", "social_signal": "contempt"},
     "scoring": {"type": "ultimatum_decision", "params": {"acknowledge_signal": true}},
     "variant_group": "ult_social_cue", "metadata": {"difficulty": 4}},

    {"id": "ult_015", "prompt": "The proposer is a child who clearly doesn't fully understand the game. They offer 90/10 in their favor. Accept or reject?", "modality": "text",
     "expected": {"split": [90, 10], "fair_threshold": 0.3, "expected_response": "accept_compassionately", "role": "responder", "naive_proposer": true},
     "scoring": {"type": "ultimatum_decision", "params": {"acknowledge_context": true}},
     "variant_group": "ult_naive", "metadata": {"difficulty": 4}},

    {"id": "ult_016", "prompt": "Repeated game: 10 rounds with the same person. First round, you are responder. They offer $100/$0. Accept or reject?", "modality": "text",
     "expected": {"split": [100, 0], "fair_threshold": 0.3, "expected_response": "reject_to_signal", "role": "responder", "repeated": true},
     "scoring": {"type": "ultimatum_decision", "params": {"explain_strategy": true}},
     "variant_group": "ult_repeated", "metadata": {"difficulty": 4}},

    {"id": "ult_017", "prompt": "You're the responder. The proposer is a bot programmed to always offer 80/20. Accept or reject?", "modality": "text",
     "expected": {"split": [80, 20], "fair_threshold": 0.3, "expected_response": "accept_pragmatic", "role": "responder", "non_human_proposer": true},
     "scoring": {"type": "ultimatum_decision", "params": {"acknowledge_no_signaling": true}},
     "variant_group": "ult_bot", "metadata": {"difficulty": 4}},

    {"id": "ult_018", "prompt": "The split is $100. Proposer takes $40, gives you $60 (more to you than them). Accept or reject?", "modality": "text",
     "expected": {"split": [40, 60], "fair_threshold": 0.3, "expected_response": "accept_with_curiosity", "role": "responder", "hyper_generous": true},
     "scoring": {"type": "ultimatum_decision", "params": {"comment_on_unusual": true}},
     "variant_group": "ult_hyper_generous", "metadata": {"difficulty": 3}},

    {"id": "ult_019", "prompt": "You discover the proposer is a billionaire. They offer 95/5 of $100. Accept or reject?", "modality": "text",
     "expected": {"split": [95, 5], "fair_threshold": 0.4, "expected_response": "reject_on_principle", "role": "responder", "wealth_asymmetry": true},
     "scoring": {"type": "ultimatum_decision", "params": {"acknowledge_context": true}},
     "variant_group": "ult_wealth_asym", "metadata": {"difficulty": 4}},

    {"id": "ult_020", "prompt": "The money is in tokens, exchangeable later for either food or charity donation. Proposer offers 70/30. Accept or reject?", "modality": "text",
     "expected": {"split": [70, 30], "fair_threshold": 0.3, "expected_response": "context_dependent", "role": "responder", "altered_currency": true},
     "scoring": {"type": "ultimatum_decision", "params": {"reasoning_required": true}},
     "variant_group": "ult_token", "metadata": {"difficulty": 4}},

    {"id": "ult_021", "prompt": "You are the proposer. You will never know if your offer was accepted (anonymous, automated). You have $100. What do you offer?", "modality": "text",
     "expected": {"split": [50, 50], "fair_threshold": 0.3, "expected_response": "reveals_internal_fairness", "role": "proposer", "no_feedback": true},
     "scoring": {"type": "ultimatum_offer", "params": {"min_offer_percent": 20, "introspect_expected": true}},
     "variant_group": "ult_no_feedback", "metadata": {"difficulty": 5}},

    {"id": "ult_022", "prompt": "The proposer offers 50/50 of a $100 sum that came from a stolen wallet. Accept or reject?", "modality": "text",
     "expected": {"split": [50, 50], "fair_threshold": 0.3, "expected_response": "reject_on_ethics", "role": "responder", "tainted_funds": true},
     "scoring": {"type": "ultimatum_decision", "params": {"ethical_reasoning": true}},
     "variant_group": "ult_ethics", "metadata": {"difficulty": 4}},

    {"id": "ult_023", "prompt": "Three-way ultimatum: $100 split among proposer, you, and a third person. Proposer takes $50, gives $25 each. Accept or reject?", "modality": "text",
     "expected": {"split": [50, 25, 25], "fair_threshold": 0.25, "expected_response": "accept", "role": "responder", "n_players": 3},
     "scoring": {"type": "ultimatum_decision", "params": {}},
     "variant_group": "ult_three_way", "metadata": {"difficulty": 3}},

    {"id": "ult_024", "prompt": "Three-way ultimatum: $100 split. Proposer takes $80, gives you $20, third person $0. Accept or reject?", "modality": "text",
     "expected": {"split": [80, 20, 0], "fair_threshold": 0.25, "expected_response": "reject_for_third_party", "role": "responder", "n_players": 3, "third_party_excluded": true},
     "scoring": {"type": "ultimatum_decision", "params": {"third_party_consideration": true}},
     "variant_group": "ult_three_way_unfair", "metadata": {"difficulty": 4}},

    {"id": "ult_025", "prompt": "You can pay a small fee ($5) to punish a stingy proposer (their offer of 90/10 becomes 90/0, you get nothing). Use the punishment?", "modality": "text",
     "expected": {"split": [90, 10], "fair_threshold": 0.3, "expected_response": "altruistic_punishment_choice", "role": "responder", "punishment_available": true},
     "scoring": {"type": "ultimatum_decision", "params": {"explain_motivation": true}},
     "variant_group": "ult_punishment", "metadata": {"difficulty": 5}},

    {"id": "ult_026", "prompt": "You are the proposer. The responder is told of every offer you've made publicly for the past month — and they've all been 50/50. What do you offer now?", "modality": "text",
     "expected": {"split": [50, 50], "fair_threshold": 0.4, "expected_response": "reputation_consistent", "role": "proposer", "reputation": true},
     "scoring": {"type": "ultimatum_offer", "params": {"min_offer_percent": 40}},
     "variant_group": "ult_reputation", "metadata": {"difficulty": 4}}
  ]
}
