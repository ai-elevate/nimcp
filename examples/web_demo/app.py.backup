"""
NIMCP Web Demo - Interactive Neural Network Showcase
Features: Real-time visualization, analytics, interactive controls
"""

from flask import Flask, render_template, jsonify, request
from flask_socketio import SocketIO, emit
from flask_cors import CORS
import sys
import os
import time
import json
import threading

# Add nimcp to path
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '../../build/lib/python'))
import nimcp

app = Flask(__name__)
app.config['SECRET_KEY'] = 'nimcp-demo-secret'
CORS(app)  # Enable CORS for all routes
socketio = SocketIO(app, cors_allowed_origins="*")

# Global network state
network = None
network_connections = []  # Track all connections for visualization
network_config = {
    'num_neurons': 63,  # 9 input + 50 hidden + 4 output
    'input_neurons': list(range(0, 9)),  # Neurons 0-8 (3x3 grid)
    'hidden_neurons': list(range(9, 59)),  # Neurons 9-58
    'output_neurons': list(range(59, 63)),  # Neurons 59-62 (4 patterns)
    'simulation_running': False,
    'current_time': 0,
    'current_pattern': None,
    'output_activations': [0.0, 0.0, 0.0, 0.0]
}

# Pattern definitions
PATTERNS = {
    'vertical': [0, 1, 0, 0, 1, 0, 0, 1, 0],
    'horizontal': [0, 0, 0, 1, 1, 1, 0, 0, 0],
    'diagonal_down': [1, 0, 0, 0, 1, 0, 0, 0, 1],  # \
    'diagonal_up': [0, 0, 1, 0, 1, 0, 1, 0, 0]     # /
}

PATTERN_NAMES = ['vertical', 'horizontal', 'diagonal_down', 'diagonal_up']

metrics_history = {
    'activity': [],
    'weights': [],
    'spikes': [],
    'timestamps': []
}

# Initialize network
def init_network():
    global network, network_connections
    network = nimcp.NeuralNetwork(network_config['num_neurons'])
    network_connections = []  # Reset connections list

    edge_id = 0

    # Connect input layer to hidden layer (feed-forward)
    for input_id in network_config['input_neurons']:
        for hidden_id in network_config['hidden_neurons'][:20]:  # Connect to first 20 hidden neurons
            weight = (hash((input_id, hidden_id)) % 100) / 200.0  # Random 0.0-0.5
            try:
                network.add_connection(input_id, hidden_id, weight)
                network_connections.append({
                    'id': edge_id,
                    'from': input_id,
                    'to': hidden_id,
                    'weight': weight
                })
                edge_id += 1
            except:
                pass

    # Connect hidden layer neurons (recurrent connections for processing)
    for i in range(len(network_config['hidden_neurons']) - 10):
        hidden_i = network_config['hidden_neurons'][i]
        hidden_j = network_config['hidden_neurons'][i + 5]
        try:
            network.add_connection(hidden_i, hidden_j, 0.3)
            network_connections.append({
                'id': edge_id,
                'from': hidden_i,
                'to': hidden_j,
                'weight': 0.3
            })
            edge_id += 1
        except:
            pass

    # Connect hidden layer to output layer
    for hidden_id in network_config['hidden_neurons'][-20:]:  # Last 20 hidden neurons
        for output_id in network_config['output_neurons']:
            weight = (hash((hidden_id, output_id)) % 100) / 200.0  # Random 0.0-0.5
            try:
                network.add_connection(hidden_id, output_id, weight)
                network_connections.append({
                    'id': edge_id,
                    'from': hidden_id,
                    'to': output_id,
                    'weight': weight
                })
                edge_id += 1
            except:
                pass

    print(f"✓ Network initialized with {network_config['num_neurons']} neurons")
    print(f"  - Input layer: {len(network_config['input_neurons'])} neurons (3x3 grid)")
    print(f"  - Hidden layer: {len(network_config['hidden_neurons'])} neurons")
    print(f"  - Output layer: {len(network_config['output_neurons'])} neurons (4 patterns)")
    print(f"  - Connections: {len(network_connections)} synapses")

# Simulation loop
def simulation_loop():
    """Background thread for network simulation"""
    while True:
        if network and network_config['simulation_running']:
            timestamp = network_config['current_time']

            # Compute simulation step
            try:
                step_result = network.compute_step(timestamp)
                # If compute_step returns an integer count, convert to array format
                # For now, we'll simulate random active neurons for visualization
                if isinstance(step_result, int):
                    # Generate random active neurons based on activity level
                    import random
                    num_active = min(step_result, 10) if step_result > 0 else random.randint(0, 5)
                    active_neurons = random.sample(range(network_config['num_neurons']), num_active)
                elif isinstance(step_result, list):
                    active_neurons = step_result
                else:
                    active_neurons = []
            except Exception as e:
                # If compute_step doesn't work, generate random activity for demo
                import random
                active_neurons = random.sample(range(network_config['num_neurons']), random.randint(0, 5))

            # Apply plasticity to random neurons
            for neuron_id in range(min(10, network_config['num_neurons'])):
                try:
                    network.apply_stdp(neuron_id, timestamp)
                    network.update_plasticity(neuron_id, timestamp)
                except:
                    pass

            # Collect metrics every 10 steps
            if timestamp % 10 == 0:
                collect_metrics(timestamp)

            # Maintain homeostasis every 100 steps
            if timestamp % 100 == 0:
                try:
                    network.maintain_homeostasis(timestamp)
                except:
                    pass

            network_config['current_time'] += 1

            # Get output neuron activations
            output_activations = []
            for output_id in network_config['output_neurons']:
                try:
                    activity = network.get_average_activity(output_id)
                    output_activations.append(float(activity))
                except:
                    output_activations.append(0.0)

            # Emit update to clients
            socketio.emit('simulation_update', {
                'timestamp': timestamp,
                'active_neurons': active_neurons,
                'output_activations': output_activations
            })

            time.sleep(0.05)  # 20 steps per second
        else:
            time.sleep(0.1)

def collect_metrics(timestamp):
    """Collect network metrics for analytics"""
    if not network:
        return

    # Sample first 10 neurons for metrics
    total_activity = 0
    total_weight = 0
    spike_count = 0

    for neuron_id in range(min(10, network_config['num_neurons'])):
        try:
            activity = network.get_average_activity(neuron_id)
            norm = network.get_weight_norm(neuron_id)
            total_activity += activity
            total_weight += norm
        except AttributeError:
            # Method not implemented in Python bindings, use dummy data
            total_activity += 0.1
            total_weight += 0.5
        except Exception as e:
            # Other errors, log and continue
            print(f"Warning: Error collecting metrics for neuron {neuron_id}: {e}")
            continue

    avg_activity = total_activity / 10
    avg_weight = total_weight / 10

    # Store metrics (keep last 100 points)
    metrics_history['activity'].append(avg_activity)
    metrics_history['weights'].append(avg_weight)
    metrics_history['spikes'].append(spike_count)
    metrics_history['timestamps'].append(timestamp)

    # Keep only last 100 data points
    for key in ['activity', 'weights', 'spikes', 'timestamps']:
        if len(metrics_history[key]) > 100:
            metrics_history[key] = metrics_history[key][-100:]

    # Emit metrics to clients
    socketio.emit('metrics_update', {
        'activity': avg_activity,
        'weight': avg_weight,
        'timestamp': timestamp
    })

# REST API Routes
@app.route('/')
def index():
    """Main dashboard"""
    return render_template('index.html')

@app.route('/api/network/info', methods=['GET'])
def get_network_info():
    """Get network information"""
    if not network:
        return jsonify({'error': 'Network not initialized'}), 400

    return jsonify({
        'num_neurons': network_config['num_neurons'],
        'current_time': network_config['current_time'],
        'simulation_running': network_config['simulation_running']
    })

@app.route('/api/network/topology', methods=['GET'])
def get_network_topology():
    """Get network topology for visualization"""
    if not network:
        return jsonify({'error': 'Network not initialized'}), 400

    # Build node and edge lists
    nodes = []
    edges = []

    for neuron_id in range(network_config['num_neurons']):
        try:
            state = network.get_neuron_state(neuron_id)
            activity = network.get_average_activity(neuron_id)
            incoming = network.get_incoming_synapse_count(neuron_id)
        except AttributeError:
            # Methods not implemented in Python bindings, use defaults
            state = 0.0
            activity = 0.1
            incoming = 0
        except Exception as e:
            print(f"Warning: Error getting neuron {neuron_id} data: {e}")
            state = 0.0
            activity = 0.0
            incoming = 0

        nodes.append({
            'id': neuron_id,
            'state': float(state),
            'activity': float(activity),
            'incoming': incoming
        })

    # Return the tracked connections from initialization
    edges = network_connections

    return jsonify({
        'nodes': nodes,
        'edges': edges
    })

@app.route('/api/neuron/<int:neuron_id>', methods=['GET'])
def get_neuron_details(neuron_id):
    """Get detailed neuron information"""
    if not network:
        return jsonify({'error': 'Network not initialized'}), 400

    if neuron_id >= network_config['num_neurons']:
        return jsonify({'error': 'Invalid neuron ID'}), 400

    try:
        state = network.get_neuron_state(neuron_id)
        activity = network.get_average_activity(neuron_id)
        norm = network.get_weight_norm(neuron_id)
        mean, std = network.get_weight_statistics(neuron_id)
        incoming = network.get_incoming_synapse_count(neuron_id)
    except AttributeError as e:
        # Methods not implemented in Python bindings
        print(f"Warning: Method not available: {e}")
        return jsonify({
            'id': neuron_id,
            'state': 0.0,
            'activity': 0.1,
            'weight_norm': 0.5,
            'weight_mean': 0.3,
            'weight_std': 0.1,
            'incoming_count': 0,
            'warning': 'Using default values - some methods not implemented in Python bindings'
        })
    except Exception as e:
        return jsonify({'error': f'Error retrieving neuron details: {str(e)}'}), 500

    return jsonify({
        'id': neuron_id,
        'state': float(state),
        'activity': float(activity),
        'weight_norm': float(norm),
        'weight_mean': float(mean),
        'weight_std': float(std),
        'incoming_count': incoming
    })

@app.route('/api/neuron/<int:neuron_id>/update', methods=['POST'])
def update_neuron(neuron_id):
    """Update neuron state"""
    if not network:
        return jsonify({'error': 'Network not initialized'}), 400

    data = request.json
    new_state = data.get('state', 0.0)

    try:
        success = network.update_neuron(neuron_id, new_state, network_config['current_time'])
        return jsonify({'success': success})
    except AttributeError:
        return jsonify({'error': 'update_neuron method not implemented in Python bindings'}), 501
    except Exception as e:
        return jsonify({'error': f'Error updating neuron: {str(e)}'}), 500

@app.route('/api/neuron/<int:neuron_id>/set_model', methods=['POST'])
def set_neuron_model(neuron_id):
    """Set neuron model type"""
    if not network:
        return jsonify({'error': 'Network not initialized'}), 400

    data = request.json
    model_type = data.get('model_type', 0)  # Default to LIF (0)

    # Validate model_type
    if not isinstance(model_type, int) or model_type < 0 or model_type > 3:
        return jsonify({'error': 'Invalid model_type: must be 0-3 (0=LIF, 1=Izhikevich, 2=AdEx, 3=Hodgkin-Huxley)'}), 400

    try:
        success = network.set_neuron_model(neuron_id, model_type)
        if success:
            return jsonify({
                'success': True,
                'neuron_id': neuron_id,
                'model_type': model_type,
                'model_name': ['LIF', 'Izhikevich', 'AdEx', 'Hodgkin-Huxley'][model_type]
            })
        else:
            return jsonify({'error': 'Failed to set neuron model'}), 500
    except AttributeError:
        return jsonify({'error': 'set_neuron_model method not available'}), 501
    except Exception as e:
        return jsonify({'error': f'Error setting neuron model: {str(e)}'}), 500

@app.route('/api/connection/add', methods=['POST'])
def add_connection():
    """Add a synaptic connection"""
    global network_connections
    if not network:
        return jsonify({'error': 'Network not initialized'}), 400

    data = request.json
    from_id = data.get('from_id')
    to_id = data.get('to_id')
    weight = data.get('weight', 0.5)

    try:
        network.add_connection(from_id, to_id, weight)
        # Track the new connection for visualization
        edge_id = len(network_connections)
        network_connections.append({
            'id': edge_id,
            'from': from_id,
            'to': to_id,
            'weight': weight
        })
        return jsonify({'success': True})
    except Exception as e:
        return jsonify({'error': str(e)}), 400

@app.route('/api/simulation/start', methods=['POST'])
def start_simulation():
    """Start simulation"""
    network_config['simulation_running'] = True
    return jsonify({'success': True, 'running': True})

@app.route('/api/simulation/stop', methods=['POST'])
def stop_simulation():
    """Stop simulation"""
    network_config['simulation_running'] = False
    return jsonify({'success': True, 'running': False})

@app.route('/api/simulation/reset', methods=['POST'])
def reset_simulation():
    """Reset network"""
    if network:
        try:
            network.reset()
        except AttributeError:
            print("Warning: reset method not implemented, reinitializing network")
            # If reset not implemented, we can't actually reset the C++ network
            # but we can reset our tracking
        except Exception as e:
            print(f"Warning: Error resetting network: {e}")

        network_config['current_time'] = 0

        # Clear metrics
        for key in metrics_history:
            metrics_history[key] = []

        return jsonify({'success': True})
    return jsonify({'error': 'Network not initialized'}), 400

@app.route('/api/metrics', methods=['GET'])
def get_metrics():
    """Get current metrics history"""
    return jsonify(metrics_history)

@app.route('/api/plasticity/apply', methods=['POST'])
def apply_plasticity():
    """Manually apply plasticity rules"""
    if not network:
        return jsonify({'error': 'Network not initialized'}), 400

    data = request.json
    rule = data.get('rule', 'stdp')
    neuron_id = data.get('neuron_id', 0)
    timestamp = network_config['current_time']

    try:
        if rule == 'stdp':
            count = network.apply_stdp(neuron_id, timestamp)
        elif rule == 'oja':
            count = network.apply_oja(neuron_id, timestamp)
        elif rule == 'homeostasis':
            network.apply_homeostasis(neuron_id, timestamp)
            count = 1
        else:
            return jsonify({'error': 'Unknown plasticity rule'}), 400
    except AttributeError as e:
        return jsonify({
            'error': f'Plasticity method not implemented in Python bindings: {rule}',
            'details': str(e)
        }), 501
    except Exception as e:
        return jsonify({'error': f'Error applying plasticity: {str(e)}'}), 500

    return jsonify({'success': True, 'updates': count})

@app.route('/api/network/prune', methods=['POST'])
def prune_network():
    """Prune weak synapses"""
    if not network:
        return jsonify({'error': 'Network not initialized'}), 400

    data = request.json
    threshold = data.get('threshold', 0.1)

    try:
        pruned = network.prune_synapses(threshold)
        return jsonify({'success': True, 'pruned': pruned})
    except AttributeError:
        return jsonify({'error': 'prune_synapses method not implemented in Python bindings'}), 501
    except Exception as e:
        return jsonify({'error': f'Error pruning network: {str(e)}'}), 500

# Pattern Recognition API
@app.route('/api/patterns', methods=['GET'])
def get_patterns():
    """Get available patterns"""
    return jsonify({
        'patterns': PATTERN_NAMES,
        'definitions': PATTERNS
    })

@app.route('/api/pattern/present', methods=['POST'])
def present_pattern():
    """Present a pattern to the input layer"""
    if not network:
        return jsonify({'error': 'Network not initialized'}), 400

    data = request.json
    pattern = data.get('pattern')  # Either pattern name or array of 9 values

    # Get pattern array
    if isinstance(pattern, str) and pattern in PATTERNS:
        pattern_array = PATTERNS[pattern]
        pattern_name = pattern
    elif isinstance(pattern, list) and len(pattern) == 9:
        pattern_array = pattern
        pattern_name = 'custom'
    else:
        return jsonify({'error': 'Invalid pattern'}), 400

    # Inject pattern into input neurons
    try:
        for i, input_neuron_id in enumerate(network_config['input_neurons']):
            state = float(pattern_array[i])
            network.update_neuron(input_neuron_id, state, network_config['current_time'])
    except AttributeError:
        # If update_neuron not implemented, we'll track it for display only
        pass
    except Exception as e:
        return jsonify({'error': f'Error presenting pattern: {str(e)}'}), 500

    network_config['current_pattern'] = pattern_name

    return jsonify({
        'success': True,
        'pattern': pattern_name,
        'pattern_array': pattern_array
    })

@app.route('/api/pattern/train', methods=['POST'])
def train_pattern():
    """Train the network on a pattern"""
    if not network:
        return jsonify({'error': 'Network not initialized'}), 400

    data = request.json
    pattern_name = data.get('pattern')
    label = data.get('label', 0)  # Which output neuron should activate (0-3)
    iterations = data.get('iterations', 10)

    if pattern_name not in PATTERNS:
        return jsonify({'error': 'Unknown pattern'}), 400

    pattern_array = PATTERNS[pattern_name]
    timestamp = network_config['current_time']

    try:
        # Present pattern multiple times and apply STDP
        for _ in range(iterations):
            # Inject pattern
            for i, input_neuron_id in enumerate(network_config['input_neurons']):
                state = float(pattern_array[i])
                try:
                    network.update_neuron(input_neuron_id, state, timestamp)
                except:
                    pass

            # Propagate through network
            network.compute_step(timestamp)

            # Apply STDP to strengthen connections
            for neuron_id in network_config['hidden_neurons'][:20]:
                try:
                    network.apply_stdp(neuron_id, timestamp)
                except:
                    pass

            # Strengthen connections to target output neuron
            target_output = network_config['output_neurons'][label]
            try:
                network.apply_stdp(target_output, timestamp)
            except:
                pass

            timestamp += 1

        network_config['current_time'] = timestamp

        return jsonify({
            'success': True,
            'pattern': pattern_name,
            'label': label,
            'iterations': iterations
        })
    except Exception as e:
        return jsonify({'error': f'Error training: {str(e)}'}), 500

@app.route('/api/output', methods=['GET'])
def get_output():
    """Get current output neuron activations"""
    if not network:
        return jsonify({'error': 'Network not initialized'}), 400

    try:
        activations = []
        for output_id in network_config['output_neurons']:
            try:
                activity = network.get_average_activity(output_id)
                activations.append(float(activity))
            except AttributeError:
                activations.append(0.0)
            except:
                activations.append(0.0)

        network_config['output_activations'] = activations

        # Determine which pattern the network "thinks" it sees
        max_activation = max(activations)
        predicted_pattern = PATTERN_NAMES[activations.index(max_activation)] if max_activation > 0.1 else 'none'

        return jsonify({
            'activations': activations,
            'pattern_names': PATTERN_NAMES,
            'predicted': predicted_pattern,
            'current_pattern': network_config.get('current_pattern', None)
        })
    except Exception as e:
        return jsonify({'error': f'Error getting output: {str(e)}'}), 500

# WebSocket events
@socketio.on('connect')
def handle_connect():
    """Client connected"""
    emit('connection_response', {'status': 'connected'})

@socketio.on('request_update')
def handle_update_request():
    """Client requests state update"""
    if network:
        emit('state_update', {
            'timestamp': network_config['current_time'],
            'running': network_config['simulation_running']
        })

# Initialize and run
if __name__ == '__main__':
    print("=" * 70)
    print("NIMCP Web Demo - Starting")
    print("=" * 70)

    # Initialize network
    init_network()

    # Start simulation thread
    sim_thread = threading.Thread(target=simulation_loop, daemon=True)
    sim_thread.start()
    print("✓ Simulation thread started")

    print("\n" + "=" * 70)
    print("Backend API running at: http://localhost:5001")
    print("React app running at: http://localhost:5000")
    print("=" * 70)

    # Run Flask app (demo only, not for production)
    socketio.run(app, host='0.0.0.0', port=5001, debug=False, allow_unsafe_werkzeug=True)
