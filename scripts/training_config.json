{
  "name": "default_progressive_training",
  "description": "Default progressive training configuration for NIMCP",
  "version": "1.0.0",
  "stages": [
    {
      "name": "infant",
      "description": "Basic sensory patterns and simple associations",
      "age_range": "0-2 years",
      "duration_samples": 5000,
      "learning_rate": 0.01,
      "consolidation_frequency": 500,
      "domains": ["sensory", "patterns"],
      "complexity_level": 0.1,
      "success_threshold": 0.7
    },
    {
      "name": "child",
      "description": "Language acquisition and simple conceptual learning",
      "age_range": "2-7 years",
      "duration_samples": 10000,
      "learning_rate": 0.008,
      "consolidation_frequency": 800,
      "domains": ["language", "literature", "social"],
      "complexity_level": 0.3,
      "success_threshold": 0.75
    },
    {
      "name": "adolescent",
      "description": "Abstract reasoning across multiple domains",
      "age_range": "7-18 years",
      "duration_samples": 15000,
      "learning_rate": 0.005,
      "consolidation_frequency": 1000,
      "domains": ["science", "mathematics", "history", "ethics", "art"],
      "complexity_level": 0.6,
      "success_threshold": 0.8
    },
    {
      "name": "adult",
      "description": "Specialized knowledge and refinement",
      "age_range": "18+ years",
      "duration_samples": 20000,
      "learning_rate": 0.002,
      "consolidation_frequency": 1500,
      "domains": ["technical", "philosophy", "general"],
      "complexity_level": 0.9,
      "success_threshold": 0.85
    }
  ],
  "hyperparameters": {
    "batch_size": 32,
    "samples_per_epoch": 1000,
    "test_set_size": 1000,
    "lr_decay_factor": 0.5,
    "consolidation_cycles": 10,
    "consolidation_strength": 0.1,
    "pruning_threshold": 0.01
  },
  "domains": {
    "sensory": {
      "description": "Basic sensory processing patterns",
      "feature_dim": 10,
      "num_classes": 5
    },
    "patterns": {
      "description": "Simple pattern recognition",
      "feature_dim": 15,
      "num_classes": 8
    },
    "language": {
      "description": "Language processing and understanding",
      "feature_dim": 30,
      "num_classes": 12
    },
    "literature": {
      "description": "Stories, narratives, themes",
      "feature_dim": 35,
      "num_classes": 10
    },
    "social": {
      "description": "Social interactions and relationships",
      "feature_dim": 25,
      "num_classes": 8
    },
    "science": {
      "description": "Scientific concepts and principles",
      "feature_dim": 40,
      "num_classes": 15
    },
    "mathematics": {
      "description": "Mathematical reasoning",
      "feature_dim": 30,
      "num_classes": 10
    },
    "history": {
      "description": "Historical events and causality",
      "feature_dim": 35,
      "num_classes": 12
    },
    "ethics": {
      "description": "Moral reasoning and values",
      "feature_dim": 25,
      "num_classes": 8
    },
    "art": {
      "description": "Aesthetic understanding",
      "feature_dim": 30,
      "num_classes": 10
    },
    "technical": {
      "description": "Technical skills and procedures",
      "feature_dim": 45,
      "num_classes": 20
    },
    "philosophy": {
      "description": "Abstract philosophical concepts",
      "feature_dim": 35,
      "num_classes": 12
    },
    "general": {
      "description": "General world knowledge",
      "feature_dim": 40,
      "num_classes": 15
    }
  },
  "notes": {
    "purpose": "This configuration implements a developmental curriculum inspired by human learning stages",
    "learning_rate_schedule": "Adaptive - starts high, decays as stage progresses",
    "consolidation": "Periodic memory consolidation prevents catastrophic forgetting",
    "multi_domain": "Rotating through domains ensures balanced knowledge acquisition",
    "checkpointing": "Saves state after each stage for rollback/analysis"
  }
}
