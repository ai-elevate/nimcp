/**
 * @file test_brain_bio_async.cpp
 * @brief Unit tests for brain bio-async integration
 *
 * Tests the bio-async message handling and communication for brain module:
 * - Initialization and shutdown
 * - Message handler registration
 * - State query handling
 * - Activation request handling
 * - Topology query handling
 * - Region config query handling
 * - Statistics tracking
 *
 * @author NIMCP Development Team
 * @date 2025-12-31
 */

#include <gtest/gtest.h>
#include <cstring>
#include <thread>
#include <chrono>

extern "C" {
#include "core/brain/nimcp_brain.h"
#include "core/brain/nimcp_brain_internal.h"
#include "async/nimcp_bio_async.h"
#include "async/nimcp_bio_router.h"
#include "async/nimcp_bio_messages.h"
#include "utils/error/nimcp_error_codes.h"
}

//=============================================================================
// Test Fixture
//=============================================================================

class BrainBioAsyncTest : public ::testing::Test {
protected:
    brain_t brain = nullptr;

    void SetUp() override {
        // Initialize bio-async first
        nimcp_bio_async_config_t async_config = nimcp_bio_async_default_config();
        async_config.enable_logging = false;
        nimcp_error_t err = nimcp_bio_async_init(&async_config);
        ASSERT_EQ(err, NIMCP_SUCCESS) << "Failed to initialize bio-async";

        // Initialize bio-router
        bio_router_config_t router_config = bio_router_default_config();
        router_config.enable_logging = false;
        err = bio_router_init(&router_config);
        ASSERT_EQ(err, NIMCP_SUCCESS) << "Failed to initialize bio-router";

        // Create brain with bio-async enabled
        brain_config_t brain_cfg = brain_default_config();
        brain_cfg.num_inputs = 10;
        brain_cfg.num_outputs = 5;
        brain_cfg.enable_bio_async = true;

        brain = brain_create(&brain_cfg);
        ASSERT_NE(brain, nullptr) << "Failed to create brain";
    }

    void TearDown() override {
        if (brain) {
            brain_destroy(brain);
            brain = nullptr;
        }
        bio_router_shutdown();
        nimcp_bio_async_shutdown();
    }
};

//=============================================================================
// Initialization Tests
//=============================================================================

TEST(BrainBioAsyncInitTest, InitWithNullBrainReturnsError) {
    nimcp_error_t err = brain_bio_async_init(nullptr);
    EXPECT_EQ(err, NIMCP_ERROR_NULL_POINTER);
}

TEST(BrainBioAsyncInitTest, ShutdownWithNullBrainIsNoop) {
    // Should not crash
    brain_bio_async_shutdown(nullptr);
}

TEST_F(BrainBioAsyncTest, BrainCreatedWithBioAsyncEnabled) {
    struct brain_struct* b = (struct brain_struct*)brain;
    // Check that bio-async context was created during brain creation
    // Note: bio_async_ctx may be NULL if brain_create doesn't auto-init bio-async
    // In that case, we need to explicitly call brain_bio_async_init
}

TEST_F(BrainBioAsyncTest, ExplicitBioAsyncInit) {
    // Create a separate brain without bio-async auto-init
    brain_config_t cfg = brain_default_config();
    cfg.num_inputs = 5;
    cfg.num_outputs = 3;
    cfg.enable_bio_async = false;

    brain_t test_brain = brain_create(&cfg);
    ASSERT_NE(test_brain, nullptr);

    // Explicitly init bio-async
    nimcp_error_t err = brain_bio_async_init(test_brain);
    EXPECT_EQ(err, NIMCP_SUCCESS);

    // Shutdown and destroy
    brain_bio_async_shutdown(test_brain);
    brain_destroy(test_brain);
}

TEST_F(BrainBioAsyncTest, DoubleInitIsIdempotent) {
    // First init (may already be initialized from brain_create)
    nimcp_error_t err1 = brain_bio_async_init(brain);
    EXPECT_EQ(err1, NIMCP_SUCCESS);

    // Second init should be idempotent
    nimcp_error_t err2 = brain_bio_async_init(brain);
    EXPECT_EQ(err2, NIMCP_SUCCESS);
}

//=============================================================================
// Message Processing Tests
//=============================================================================

TEST_F(BrainBioAsyncTest, ProcessMessagesReturnsZeroWhenEmpty) {
    // Initialize bio-async for this brain
    nimcp_error_t err = brain_bio_async_init(brain);
    EXPECT_EQ(err, NIMCP_SUCCESS);

    // Process messages when inbox is empty
    uint32_t processed = brain_bio_async_process_messages(brain, 10);
    EXPECT_EQ(processed, 0u);
}

TEST_F(BrainBioAsyncTest, ProcessMessagesWithNullBrain) {
    uint32_t processed = brain_bio_async_process_messages(nullptr, 10);
    EXPECT_EQ(processed, 0u);
}

TEST_F(BrainBioAsyncTest, UpdateWithNullBrain) {
    // Should not crash
    brain_bio_async_update(nullptr);
}

//=============================================================================
// Statistics Tests
//=============================================================================

TEST_F(BrainBioAsyncTest, GetStatsWithNullBrain) {
    uint64_t sent = 0, received = 0, queries = 0, activations = 0;
    bool success = brain_bio_async_get_stats(nullptr, &sent, &received, &queries, &activations);
    EXPECT_FALSE(success);
}

TEST_F(BrainBioAsyncTest, GetStatsWithValidBrain) {
    // Initialize bio-async
    nimcp_error_t err = brain_bio_async_init(brain);
    EXPECT_EQ(err, NIMCP_SUCCESS);

    uint64_t sent = 0, received = 0, queries = 0, activations = 0;
    bool success = brain_bio_async_get_stats(brain, &sent, &received, &queries, &activations);
    EXPECT_TRUE(success);

    // Initially should be zero
    EXPECT_EQ(sent, 0u);
    EXPECT_EQ(received, 0u);
    EXPECT_EQ(queries, 0u);
    EXPECT_EQ(activations, 0u);
}

TEST_F(BrainBioAsyncTest, GetStatsWithNullOutputs) {
    // Initialize bio-async
    nimcp_error_t err = brain_bio_async_init(brain);
    EXPECT_EQ(err, NIMCP_SUCCESS);

    // Should handle NULL output pointers gracefully
    bool success = brain_bio_async_get_stats(brain, nullptr, nullptr, nullptr, nullptr);
    EXPECT_TRUE(success);
}

//=============================================================================
// Update Tests
//=============================================================================

TEST_F(BrainBioAsyncTest, UpdatePublishesSignals) {
    // Initialize bio-async
    nimcp_error_t err = brain_bio_async_init(brain);
    EXPECT_EQ(err, NIMCP_SUCCESS);

    // Call update - should publish state signals
    brain_bio_async_update(brain);

    // Get stats - messages_sent should increase
    uint64_t sent = 0, received = 0, queries = 0, activations = 0;
    bool success = brain_bio_async_get_stats(brain, &sent, &received, &queries, &activations);
    EXPECT_TRUE(success);
    // Note: sent count depends on whether predictive models were created
}

//=============================================================================
// Error Handling Tests
//=============================================================================

TEST_F(BrainBioAsyncTest, InitWithUninitializedBioAsync) {
    // Create a brain with bio-async disabled
    brain_config_t cfg = brain_default_config();
    cfg.num_inputs = 5;
    cfg.num_outputs = 3;
    cfg.enable_bio_async = false;

    brain_t test_brain = brain_create(&cfg);
    ASSERT_NE(test_brain, nullptr);

    // Try to init bio-async - should work since global bio-async is initialized
    nimcp_error_t err = brain_bio_async_init(test_brain);
    EXPECT_EQ(err, NIMCP_SUCCESS);

    brain_bio_async_shutdown(test_brain);
    brain_destroy(test_brain);
}

//=============================================================================
// Edge Cases
//=============================================================================

TEST_F(BrainBioAsyncTest, MultipleProcessCycles) {
    // Initialize bio-async
    nimcp_error_t err = brain_bio_async_init(brain);
    EXPECT_EQ(err, NIMCP_SUCCESS);

    // Multiple process cycles should be safe
    for (int i = 0; i < 100; i++) {
        brain_bio_async_process_messages(brain, 0);  // 0 = all
        brain_bio_async_update(brain);
    }

    // Should still be able to get stats
    uint64_t sent = 0, received = 0, queries = 0, activations = 0;
    bool success = brain_bio_async_get_stats(brain, &sent, &received, &queries, &activations);
    EXPECT_TRUE(success);
}

TEST_F(BrainBioAsyncTest, ShutdownTwiceIsNoop) {
    // Initialize bio-async
    nimcp_error_t err = brain_bio_async_init(brain);
    EXPECT_EQ(err, NIMCP_SUCCESS);

    // Shutdown twice
    brain_bio_async_shutdown(brain);
    brain_bio_async_shutdown(brain);  // Should be safe

    // Brain should still be valid for other operations
    uint32_t neuron_count = brain_get_neuron_count(brain);
    EXPECT_GT(neuron_count, 0u);
}
