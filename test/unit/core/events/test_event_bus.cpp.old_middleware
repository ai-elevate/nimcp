TEST_F(EventBusTest, SubscribeWithPriorityOrdering) {
    // WHAT: Test subscriber priority ordering
    // WHY:  Verify high priority subscribers are called first
    // HOW:  Create subscribers with different priorities, verify order

    bus = event_bus_create(nullptr);
    ASSERT_NE(bus, nullptr);

    std::vector<int> call_order;
    auto make_callback = [&call_order](int id) {
        return [&call_order, id](const event_t* e, void* ctx) {
            call_order.push_back(id);
        };
    };

    subscription_config_t cfg_low = subscriber_default_config();
    cfg_low.priority = SUBSCRIBER_PRIORITY_LOW;
    subscription_config_t cfg_high = subscriber_default_config();
    cfg_high.priority = SUBSCRIBER_PRIORITY_HIGH;
    subscription_config_t cfg_highest = subscriber_default_config();
    cfg_highest.priority = SUBSCRIBER_PRIORITY_HIGHEST;

    event_bus_subscribe(bus, make_callback(1), nullptr, &cfg_low);
    event_bus_subscribe(bus, make_callback(2), nullptr, &cfg_high);
    event_bus_subscribe(bus, make_callback(3), nullptr, &cfg_highest);

    event_t event = create_test_event();
    event_bus_publish(bus, &event);
    event_bus_process_events(bus, 10);

    ASSERT_EQ(call_order.size(), 3u);
    EXPECT_EQ(call_order[0], 3);  // Highest priority first
    EXPECT_EQ(call_order[1], 2);  // High priority second
    EXPECT_EQ(call_order[2], 1);  // Low priority last
}

