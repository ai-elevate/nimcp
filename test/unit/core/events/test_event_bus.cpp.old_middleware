    bus = event_bus_create(nullptr);
    ASSERT_NE(bus, nullptr);

    const int num_threads = 4;
    const int events_per_thread = 100;
    std::vector<std::thread> threads;

    for (int t = 0; t < num_threads; t++) {
        threads.emplace_back([this, events_per_thread]() {
            for (int i = 0; i < events_per_thread; i++) {
                event_t event = create_test_event();
                event_bus_publish(bus, &event);
            }
        });
    }

    for (auto& thread : threads) {
        thread.join();
    }

    event_bus_stats_t stats;
    EXPECT_TRUE(event_bus_get_stats(bus, &stats));
    EXPECT_EQ(stats.events_published, num_threads * events_per_thread);
}

