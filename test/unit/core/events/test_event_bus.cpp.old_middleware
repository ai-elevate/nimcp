TEST_F(EventBusTest, PublishUntilFull) {
    // WHAT: Test queue overflow behavior
    // WHY:  Verify overflow policy works correctly
    // HOW:  Fill queue to capacity, check behavior

    event_bus_config_t config = event_bus_default_config();
    config.queue_capacity = 10;
    config.overflow_policy = OVERFLOW_POLICY_DROP_NEWEST;

    bus = event_bus_create(&config);
    ASSERT_NE(bus, nullptr);

    // Fill queue
    for (int i = 0; i < 10; i++) {
        event_t event = create_test_event();
        EXPECT_TRUE(event_bus_publish(bus, &event));
    }

    // Next event should be dropped
    event_t event = create_test_event();
    EXPECT_FALSE(event_bus_publish(bus, &event));

    event_bus_stats_t stats;
    EXPECT_TRUE(event_bus_get_stats(bus, &stats));
    EXPECT_EQ(stats.events_published, 10u);
    EXPECT_EQ(stats.queue_size, 10u);
}

