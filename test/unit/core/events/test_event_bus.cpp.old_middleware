/**
 * WHAT: Test fixture for event bus tests
 * WHY:  Provide common setup/teardown and helper functions
 * HOW:  SetUp creates resources, TearDown cleans them up
 */
class EventBusTest : public ::testing::Test {
protected:
    event_bus_t bus;
    std::vector<event_t> received_events;
    std::atomic<int> callback_count{0};
    std::atomic<int> error_count{0};

    void SetUp() override {
        bus = nullptr;
        received_events.clear();
        callback_count = 0;
        error_count = 0;
    }

    void TearDown() override {
        if (bus) {
            event_bus_destroy(bus);
            bus = nullptr;
        }
        received_events.clear();
    }

    // Helper: Simple callback that counts invocations
    static void simple_callback(const event_t* event, void* context) {
        auto* test = static_cast<EventBusTest*>(context);
        test->callback_count++;
    }

    // Helper: Callback that stores events
    static void storing_callback(const event_t* event, void* context) {
        auto* test = static_cast<EventBusTest*>(context);
        test->received_events.push_back(*event);
        test->callback_count++;
    }

    // Helper: Filter for specific event type
    static bool type_filter(const event_t* event, void* context) {
        event_type_t* target_type = static_cast<event_type_t*>(context);
        return event->type == *target_type;
    }

    // Helper: Create test event
    event_t create_test_event(event_type_t type = EVENT_TYPE_SPIKE_BURST,
                              event_priority_t priority = EVENT_PRIORITY_NORMAL) {
        uint32_t neurons[] = {1, 2, 3};
        return event_create_spike_burst(neurons, 3, 0.8f, 1000,
                                        priority, EVENT_SOURCE_ENCODER);
    }
};

