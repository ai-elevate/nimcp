#==============================================================================
# Valgrind Suppressions File for NIMCP
#==============================================================================
# This file suppresses known false positives from valgrind
# Particularly for Python C API and system libraries
#==============================================================================

# Python C API allocations
{
   python_malloc
   Memcheck:Leak
   ...
   fun:PyMalloc_*
}

{
   python_realloc
   Memcheck:Leak
   ...
   fun:PyRealloc_*
}

{
   python_object_malloc
   Memcheck:Leak
   ...
   fun:PyObject_Malloc
}

{
   python_mem_malloc
   Memcheck:Leak
   ...
   fun:PyMem_Malloc
}

# Python initialization leaks (expected)
{
   python_init
   Memcheck:Leak
   ...
   fun:Py_Initialize*
}

{
   python_finalize
   Memcheck:Leak
   ...
   fun:Py_Finalize*
}

# GTest known suppressions
{
   gtest_init
   Memcheck:Leak
   ...
   fun:_ZN7testing*
}

# Thread library suppressions
{
   pthread_create
   Memcheck:Leak
   ...
   fun:pthread_create*
}

# System library suppressions
{
   dl_open
   Memcheck:Leak
   ...
   fun:_dl_open
}

{
   dl_init
   Memcheck:Leak
   ...
   fun:_dl_init
}
